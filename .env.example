# ─── Database ───
DATABASE_URL=postgresql://hallakompis:hallakompis@localhost:5432/hallakompis

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── Claude ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── Web ───
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Auth ───
# Generer med: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Google OAuth (for kalender + Gmail) ───
# Hentes fra https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# ─── Slack (valgfritt, kommer i v1) ───
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ─── ElevenLabs TTS (valgfritt, voice fase 2) ───
# Mangler nøkkel/voice-ID? /voice/tts svarer 501 og klient faller tilbake til browser-TTS.
ELEVENLABS_API_KEY=
# Voice-ID fra https://elevenlabs.io/app/voice-library (helst en flerspråklig stemme for nb-NO)
ELEVENLABS_VOICE_ID=
# Valgfritt — overstyr modell. Default: eleven_turbo_v2_5
ELEVENLABS_MODEL_ID=
